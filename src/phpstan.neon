includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon

parameters:
    level: max

    paths:
        - app
        - bootstrap/app.php
        - bootstrap/providers.php
        - config
        - database/factories
        - database/migrations
        - database/seeders
        - routes
        - tests
